# Environment Variables for LLMRouter
# Copy this file to .env and fill in your values

# ──────────────────────────────────────────────
# LLM Provider API Keys
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# vLLM self-hosted base URL (OpenAI-compatible)
# Leave blank to disable vLLM adapter
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL_NAME=local-8b-instruct

# ──────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=llmrouter
POSTGRES_USER=llmrouter
POSTGRES_PASSWORD=llmrouter_secret

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ──────────────────────────────────────────────
# Kafka
# ──────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
SERVER_PORT=8080
LOG_LEVEL=INFO

# Development API key (for seeded dev tenant)
DEV_API_KEY=dev-api-key

# ──────────────────────────────────────────────
# Observability (optional)
# ──────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_ENABLED=true
